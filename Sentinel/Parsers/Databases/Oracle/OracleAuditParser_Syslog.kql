    83, "DROP TYPE BODY",
    84, "DROP LIBRARY",
    85, "TRUNCATE TABLE",
    86, "TRUNCATE CLUSTER",
    91, "CREATE FUNCTION",
    92, "ALTER FUNCTION",
    93, "DROP FUNCTION",
    94, "CREATE PACKAGE",
    95, "ALTER PACKAGE",
    96, "DROP PACKAGE",
    97, "CREATE PACKAGE BODY",
    98, "ALTER PACKAGE BODY",
    99, "DROP PACKAGE BODY",
    100, "LOGON",
    101, "LOGOFF",
    102, "LOGOFF BY CLEANUP",
    103, "SESSION REC",
    104, "SYSTEM AUDIT",
    105, "SYSTEM NOAUDIT",
    106, "AUDIT DEFAULT",
