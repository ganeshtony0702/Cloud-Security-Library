    108, "SYSTEM GRANT",
    109, "SYSTEM REVOKE",
    110, "CREATE PUBLIC SYNONYM",
    111, "DROP PUBLIC SYNONYM",
    112, "CREATE PUBLIC DATABASE LINK",
    113, "DROP PUBLIC DATABASE LINK",
    114, "GRANT ROLE",
    115, "REVOKE ROLE",
    116, "EXECUTE PROCEDURE",
    117, "USER COMMENT",
    118, "ENABLE TRIGGER",
    119, "DISABLE TRIGGER",
