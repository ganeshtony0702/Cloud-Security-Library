    178, "DROP CONTEXT",
    179, "ALTER OUTLINE",
    180, "CREATE OUTLINE",
    181, "DROP OUTLINE",
    182, "UPDATE INDEXES",
    183, "ALTER OPERATOR",
    197, "PURGE USER_RECYCLEBIN",
    198, "PURGE DBA_RECYCLEBIN",
    199, "PURGE TABLESPACE",
    200, "PURGE TABLE",
    201, "PURGE INDEX",
    202, "UNDROP OBJECT",
    204, "FLASHBACK DATABASE",
    205, "FLASHBACK TABLE",
    206, "CREATE RESTORE POINT",
    207, "DROP RESTORE POINT",
    208, "PROXY AUTHENTICATION ONLY",
    209, "DECLARE REWRITE EQUIVALENCE",
    210, "ALTER REWRITE EQUIVALENCE",
    211, "DROP REWRITE EQUIVALENCE"
];
Syslog
| where SyslogMessage has "Oracle Audit" or SyslogMessage has "Oracle Unified Audit"
| extend LogType = case(
                       SyslogMessage has "Oracle Unified Audit",
                       "Oracle Unified Audit",
                       SyslogMessage has "Oracle Audit",
                       "Oracle Audit",
                       "Unknown"
                   )
// =========================
// 🔹 Unified Audit Parsing
// =========================
| extend UA_DBUser = extract(@"DBUSER:\""?([^\""]+)\""?", 1, SyslogMessage)
| extend UA_ActionCode = toint(extract(@"ACTION:\""?(\d+)\""?", 1, SyslogMessage))
| extend UA_ReturnCode = extract(@"RETCODE:\""?([^\""]+)\""?", 1, SyslogMessage)
| extend UA_Object = extract(@"OBJNAME:\""?([^\""]+)\""?", 1, SyslogMessage)
| extend UA_Schema = extract(@"SCHEMA:\""?([^\""]+)\""?", 1, SyslogMessage)
| extend UA_SessionId = extract(@"SESID:\""?([^\""]+)\""?", 1, SyslogMessage)
// =========================
// 🔹 Oracle Audit (OS/ASM)
// =========================
| extend OA_ActionRaw = extract(@"ACTION\s*:\[\d+\]\s*'([^']+)'", 1, SyslogMessage)
| extend OA_ActionCode = toint(extract(@"ACTION\s*:\[(\d+)\]", 1, SyslogMessage))
| extend OA_ActionNumber = toint(extract(@"ACTION NUMBER:\[(\d+)\]", 1, SyslogMessage))
| extend OA_DBUser = extract(@"DATABASE USER:\[\d+\]\s*'([^']+)'", 1, SyslogMessage)
| extend OA_Status = extract(@"STATUS:\[\d+\]\s*'([^']+)'", 1, SyslogMessage)
| extend OA_UserHost = extract(@"USERHOST:\[\d+\]\s*'([^']+)'", 1, SyslogMessage)
// =========================
// 🔹 Normalize SQL_TEXT
// =========================
| extend SQLText = case(
                       LogType == "Oracle Audit" and OA_ActionRaw has "select",
                       OA_ActionRaw,
                       LogType == "Oracle Audit" and OA_ActionRaw has "insert",
                       OA_ActionRaw,
                       LogType == "Oracle Audit" and OA_ActionRaw has "update",
                       OA_ActionRaw,
                       LogType == "Oracle Audit" and OA_ActionRaw has "delete",
                       OA_ActionRaw,
                       ""
                   )
// =========================
// 🔹 Action Mapping
// =========================
| extend FinalActionCode = case(
                               LogType == "Oracle Unified Audit",
                               UA_ActionCode,
                               LogType == "Oracle Audit",
                               coalesce(OA_ActionNumber, OA_ActionCode),
                               int(null)
                           )
| lookup ActionMap on $left.FinalActionCode == $right.ActionNumber
// =========================
// 🔹 Final Projection
// =========================
| project
    TimeGenerated,
    LogType,
    // Users
    DBUser = coalesce(UA_DBUser, OA_DBUser),
    // Action
    ActionCode = FinalActionCode,
    ActionName,
    // SQL
    SQLText,
    // Status
    Status = coalesce(UA_ReturnCode, OA_Status),
    // Object
    ObjectName = UA_Object,
    Schema = UA_Schema,
    // Session
    SessionId = coalesce(UA_SessionId, ""),
    // Host
    Host = OA_UserHost,
    RawLog = SyslogMessage
